{
  "name": "nanostores",
  "version": "1.4.0",
  "description": "A tiny (340 bytes) state manager for React/Preact/Vue/Svelte with many atomic tree-shakable stores",
  "keywords": [
    "preact",
    "react",
    "react native",
    "state",
    "state manager",
    "store",
    "svelte",
    "vue"
  ],
  "license": "MIT",
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "repository": "nanostores/nanostores",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test:lint": "oxlint",
    "test:coverage": "pnpm bnt --coverage 100 --coverage-exclude '**/*.test.ts'",
    "test:types": "check-dts",
    "test:size": "size-limit",
    "test": "pnpm run /^test:/"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.0",
    "@sinonjs/fake-timers": "^15.4.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.0",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@types/ws": "^8.18.1",
    "actions-up": "^1.16.0",
    "benchmark": "^2.1.4",
    "better-node-test": "^0.8.4",
    "check-dts": "^1.0.0",
    "eslint-plugin-prefer-let": "^4.2.2",
    "multiocular": "^0.8.3",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "size-limit": "^12.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "size-limit": [
    {
      "name": "Atom",
      "import": {
        "./index.js": "{ atom }"
      },
      "limit": "340 B"
    },
    {
      "name": "Popular Set",
      "import": {
        "./index.js": "{ map, computed }"
      },
      "limit": "864 B"
    }
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "clean-publish": {
    "cleanDocs": true
  }
}
